# Copy to .env and fill in values for local development
# (Never commit .env to version control)

REDIS_URL=redis://127.0.0.1:6379
DATABASE_URL=postgres://rl_user:rl_pass@127.0.0.1:5432/ratelimiter
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# Load test settings (used by tests/load.js)
LOAD_TARGET_URL=http://127.0.0.1:3000
LOAD_CONNECTIONS=50
LOAD_DURATION=10
LOAD_API_KEY=test-key-open

# Tier 3: Admin API (x-admin-key header must match this value)
ADMIN_KEY=admin-secret-change-me-in-production

# Tier 3: CORS allowed origins (comma-separated; leave unset to disable CORS)
# ALLOWED_ORIGINS=http://localhost:3000,https://your-dashboard.example.com
